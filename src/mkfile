<$PLAN9/src/mkhdr

TARG=9ai

OFILES=\
	main.$O\
	port.$O\
	http.$O\
	json.$O\
	oauth.$O\
	models.$O\
	sse.$O\
	oai.$O\
	exec.$O\
	agent.$O\
	fs.$O\

HFILES=\
	9ai.h\
	http.h\
	json.h\
	oauth.h\
	models.h\
	sse.h\
	oai.h\
	exec.h\
	agent.h\
	fs.h\

<$PLAN9/src/mkone

# Stage 1: smoke-test port.c helpers
test-port:V: $O.$TARG
	./$O.$TARG

# Stage 2: test HTTP client via 9aitls proxy
# Start proxy first:  ./9aitls &
# Requires ~/lib/9ai/token (GitHub access token)
$O.httptest: httptest.$O port.$O http.$O json.$O
	$LD $LDFLAGS -o $target $prereq

test-http:V: $O.httptest
	./$O.httptest

# Stage 3: unit-test JSON helpers
$O.jsontest: jsontest.$O json.$O port.$O
	$LD $LDFLAGS -o $target $prereq

test-json:V: $O.jsontest
	./$O.jsontest

# Stage 4: OAuth device flow + session token
$O.oauthtest: oauthtest.$O port.$O http.$O json.$O oauth.$O
	$LD $LDFLAGS -o $target $prereq

test-oauth:V: $O.oauthtest
	./$O.oauthtest -s ~/.cache/9ai/proxy.sock -t ~/.cache/9ai/token

# Stage 5: /models fetch + parser
$O.modelstest: modelstest.$O port.$O http.$O json.$O oauth.$O models.$O
	$LD $LDFLAGS -o $target $prereq

test-models:V: $O.modelstest
	./$O.modelstest -s ~/.cache/9ai/proxy.sock -t ~/.cache/9ai/token

# Stage 6: SSE line parser
$O.ssetest: ssetest.$O port.$O http.$O json.$O oauth.$O sse.$O
	$LD $LDFLAGS -o $target $prereq

test-sse:V: $O.ssetest
	./$O.ssetest -s ~/.cache/9ai/proxy.sock -t ~/.cache/9ai/token

# Stage 7: OpenAI Completions request builder + SSE delta parser
$O.oaitest: oaitest.$O port.$O http.$O json.$O oauth.$O sse.$O oai.$O
	$LD $LDFLAGS -o $target $prereq

test-oai:V: $O.oaitest
	./$O.oaitest -s ~/.cache/9ai/proxy.sock -t ~/.cache/9ai/token

# Stage 8: exec tool — parse args, threadspawn, collect output
$O.exectest: exectest.$O port.$O json.$O exec.$O
	$LD $LDFLAGS -o $target $prereq

test-exec:V: $O.exectest
	./$O.exectest

# Stage 9: agent loop (OAI format) — tool loop, emit_event, write_session
$O.agenttest: agenttest.$O port.$O http.$O json.$O oauth.$O sse.$O oai.$O exec.$O agent.$O
	$LD $LDFLAGS -o $target $prereq

test-agent:V: $O.agenttest
	./$O.agenttest -s ~/.cache/9ai/proxy.sock -t ~/.cache/9ai/token

# Stage 11: 9P server
$O.fstest: fstest.$O port.$O http.$O json.$O oauth.$O models.$O sse.$O oai.$O exec.$O agent.$O fs.$O
	$LD $LDFLAGS -o $target $prereq

test-fs:V: $O.fstest
	./$O.fstest -s ~/.cache/9ai/proxy.sock -t ~/.cache/9ai/token
