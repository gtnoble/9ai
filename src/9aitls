#!/usr/bin/env python3
"""
9aitls — TLS proxy for 9ai

Listens on a Unix domain socket and forwards each connection to the
correct upstream host over TLS.  The upstream host is taken from the
HTTP Host: header of each request, so the proxy is fully transparent —
9ai can reach any HTTPS host without knowing about TLS at all.

Usage:
    9aitls [-s sockpath] [-p port]

Defaults:
    sockpath  ~/lib/9ai/proxy.sock
    port      443

On connect:
    1. Read the full HTTP request (headers + body) from the Unix socket.
    2. Extract the Host: header to determine the upstream hostname.
    3. Open a TLS TCP connection to that host:port.
    4. Forward the request verbatim.
    5. Decode chunked transfer encoding if present (C client expects plain).
    6. Stream the response back until upstream closes.
    7. Close both sides.

Plan 9 native port:
    Replace with an rc script using tlssrv(8) as a filter.  The Unix
    socket interface and the C client code are unchanged.
"""

import os
import sys
import ssl
import socket
import threading
import argparse
import signal

DEFAULT_PORT = 443
DEFAULT_SOCK = os.path.expanduser("~/lib/9ai/proxy.sock")

CHUNK = 65536


def parse_request(buf):
    """
    Given a complete HTTP request buffer, return (host, content_length).
    host is extracted from the Host: header (port stripped).
    """
    host = None
    content_length = 0

    for sep in (b"\r\n\r\n", b"\n\n"):
        idx = buf.find(sep)
        if idx == -1:
            continue
        header_block = buf[:idx]
        for line in header_block.split(b"\n"):
            line = line.strip()
            lo = line.lower()
            if lo.startswith(b"host:"):
                val = line[5:].strip()
                # strip port if present
                if b":" in val:
                    val = val.split(b":")[0]
                host = val.decode(errors="replace")
            elif lo.startswith(b"content-length:"):
                try:
                    content_length = int(line.split(b":", 1)[1].strip())
                except ValueError:
                    pass
        break

    return host, content_length


def read_request(sock):
    """
    Read one complete HTTP/1.1 request from sock.
    Returns (raw_bytes, host) or (b'', None) on EOF/error.
    """
    buf = b""
    header_done = False
    content_length = 0
    host = None
    header_end = 0

    while True:
        chunk = sock.recv(CHUNK)
        if not chunk:
            return b"", None
        buf += chunk

        if not header_done:
            for sep in (b"\r\n\r\n", b"\n\n"):
                idx = buf.find(sep)
                if idx != -1:
                    header_end = idx + len(sep)
                    header_done = True
                    host, content_length = parse_request(buf)
                    break

        if header_done:
            body_len = len(buf) - header_end
            if body_len >= content_length:
                return buf[:header_end + content_length], host


def read_response_headers(upstream):
    """
    Read HTTP response status line + headers from upstream.
    Returns (status_line_bytes, headers_dict, raw_header_bytes, leftover, is_chunked).
    """
    buf = b""
    while True:
        chunk = upstream.recv(CHUNK)
        if not chunk:
            break
        buf += chunk
        for sep in (b"\r\n\r\n", b"\n\n"):
            idx = buf.find(sep)
            if idx != -1:
                header_block = buf[:idx]
                leftover = buf[idx + len(sep):]
                lines = header_block.split(b"\n")
                status_line = lines[0].strip()
                headers = {}
                for line in lines[1:]:
                    line = line.strip()
                    if b":" in line:
                        k, _, v = line.partition(b":")
                        headers[k.strip().lower()] = v.strip()
                is_chunked = headers.get(b"transfer-encoding", b"").lower() == b"chunked"
                return status_line, headers, header_block + sep, leftover, is_chunked
    return b"", {}, buf, b"", False


def decode_chunked(upstream, leftover):
    """
    Decode chunked transfer-encoding, yielding body byte strings.
    """
    buf = leftover
    while True:
        while b"\n" not in buf:
            more = upstream.recv(CHUNK)
            if not more:
                return
            buf += more
        line_end = buf.index(b"\n") + 1
        size_line = buf[:line_end].strip().split(b";")[0].strip()
        buf = buf[line_end:]
        try:
            chunk_size = int(size_line, 16)
        except ValueError:
            return
        if chunk_size == 0:
            return
        while len(buf) < chunk_size:
            more = upstream.recv(CHUNK)
            if not more:
                yield buf
                return
            buf += more
        yield buf[:chunk_size]
        buf = buf[chunk_size:]
        while buf and buf[0:1] in (b"\r", b"\n"):
            buf = buf[1:]


def handle(client_sock, default_host, upstream_port):
    """Handle one client connection."""
    request, host = read_request(client_sock)
    if not request:
        client_sock.close()
        return

    # Fall back to default host if Host header absent (shouldn't happen)
    if not host:
        host = default_host

    ctx = ssl.create_default_context()
    try:
        raw = socket.create_connection((host, upstream_port), timeout=30)
        upstream = ctx.wrap_socket(raw, server_hostname=host)
    except OSError as e:
        print(f"9aitls: connect {host}:{upstream_port} failed: {e}", file=sys.stderr)
        client_sock.close()
        return

    try:
        upstream.sendall(request)

        status_line, headers, raw_headers, leftover, is_chunked = \
            read_response_headers(upstream)

        if is_chunked:
            status_str = status_line.decode(errors="replace")
            clean_headers = f"{status_str}\r\nConnection: close\r\n\r\n".encode()
            client_sock.sendall(clean_headers)
            for chunk in decode_chunked(upstream, leftover):
                client_sock.sendall(chunk)
        else:
            client_sock.sendall(raw_headers)
            if leftover:
                client_sock.sendall(leftover)
            while True:
                data = upstream.recv(CHUNK)
                if not data:
                    break
                client_sock.sendall(data)

    except OSError as e:
        print(f"9aitls: relay error ({host}): {e}", file=sys.stderr)
    finally:
        try:
            upstream.close()
        except OSError:
            pass
        try:
            client_sock.close()
        except OSError:
            pass


def serve(sockpath, default_host, upstream_port):
    try:
        os.unlink(sockpath)
    except FileNotFoundError:
        pass

    os.makedirs(os.path.dirname(sockpath), exist_ok=True)

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(sockpath)
    os.chmod(sockpath, 0o600)
    server.listen(32)

    print(f"9aitls: listening on {sockpath} (port {upstream_port})", file=sys.stderr)

    def _cleanup(sig, frame):
        try:
            os.unlink(sockpath)
        except OSError:
            pass
        sys.exit(0)
    signal.signal(signal.SIGTERM, _cleanup)
    signal.signal(signal.SIGINT, _cleanup)

    while True:
        try:
            conn, _ = server.accept()
        except OSError:
            break
        t = threading.Thread(target=handle,
                             args=(conn, default_host, upstream_port),
                             daemon=True)
        t.start()


def main():
    ap = argparse.ArgumentParser(description="TLS proxy for 9ai")
    ap.add_argument("-s", "--sock", default=DEFAULT_SOCK,
                    help=f"Unix socket path (default: {DEFAULT_SOCK})")
    ap.add_argument("-H", "--host", default="api.individual.githubcopilot.com",
                    help="Default upstream host if Host header absent")
    ap.add_argument("-p", "--port", type=int, default=DEFAULT_PORT,
                    help=f"Upstream TLS port (default: {DEFAULT_PORT})")
    args = ap.parse_args()

    serve(args.sock, args.host, args.port)


if __name__ == "__main__":
    main()
